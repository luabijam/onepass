{
  "name": "@onepass/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "OnePass desktop app for macOS",
  "main": "index.js",
  "scripts": {
    "macos": "react-native run-macos",
    "macos:release": "cd macos && xcodebuild -workspace desktop.xcworkspace -scheme desktop-macOS -configuration Release -derivedDataPath build",
    "macos:sign": "../../scripts/build-signed.sh",
    "macos:notarize": "../../scripts/notarize.sh macos/build/Build/Products/Release/OnePass.app",
    "macos:distribute": "npm run macos:sign && npm run macos:notarize",
    "macos:clean": "rm -rf macos/build",
    "macos:pod": "cd macos && pod install",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf macos/build"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@onepass/vault-core": "*",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "crypto-browserify": "^3.12.1",
    "express": "^5.2.1",
    "keytar": "^7.9.0",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-crypto": "^2.2.1",
    "react-native-macos": "0.76.6",
    "react-native-vector-icons": "^10.3.0",
    "stream-browserify": "^3.0.0",
    "vm-browserify": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.76.6",
    "@react-native/eslint-config": "0.76.6",
    "@react-native/metro-config": "0.76.6",
    "@react-native/typescript-config": "0.76.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "axios": "^1.13.6",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "prettier": "^3.2.5",
    "react-test-renderer": "18.3.1",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
