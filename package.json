{
  "name": "onepass",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform password manager with React Native",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "build:release": "npm run build --workspace=@onepass/vault-core",
    "build:android": "npm run build:release && npm run android:release --workspace=@onepass/mobile",
    "build:android:debug": "npm run build:release && npm run android:debug --workspace=@onepass/mobile",
    "build:ios": "npm run build:release && npm run ios --workspace=@onepass/mobile",
    "build:macos": "npm run build:release && npm run macos --workspace=@onepass/desktop",
    "build:macos:release": "npm run build:release && npm run macos:release --workspace=@onepass/desktop",
    "build:all": "npm run build:android && npm run build:macos",
    "build:all:release": "npm run build:android && npm run build:macos:release",
    "dev": "npm run dev -ws --if-present",
    "dev:vault": "npm run dev --workspace=@onepass/vault-core",
    "dev:mobile": "npm run dev --workspace=@onepass/mobile",
    "dev:desktop": "npm run dev --workspace=@onepass/desktop",
    "test": "npm run test -ws --if-present",
    "test:vault": "npm run test --workspace=@onepass/vault-core",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "lint:fix": "eslint packages/*/src --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "npm run typecheck -ws --if-present",
    "clean": "npm run clean -ws --if-present && rm -rf node_modules",
    "android": "npm run android --workspace=@onepass/mobile",
    "android:release": "npm run android:release --workspace=@onepass/mobile",
    "ios": "npm run ios --workspace=@onepass/mobile",
    "macos": "npm run macos --workspace=@onepass/desktop",
    "macos:release": "npm run macos:release --workspace=@onepass/desktop"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  }
}
